#include <stdio.h>
#include <limits.h>

int main() {
    int n, i, j, src, u;
    int cost[10][10], dist[10], visited[10] = {0};

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
            // Often, if there is no edge, the input is 0. 
            // In Dijkstra, no edge should be treated as infinity.
            if (cost[i][j] == 0 && i != j) {
                cost[i][j] = INT_MAX;
            }
        }
    }

    printf("Enter source vertex: ");
    scanf("%d", &src);

    // Initialization
    for (i = 0; i < n; i++) {
        dist[i] = cost[src][i];
        visited[i] = 0;
    }

    dist[src] = 0;
    visited[src] = 1;

    // Main Dijkstra Logic
    for (i = 1; i < n; i++) {
        int min = INT_MAX;

        // Find the unvisited vertex with the minimum distance
        for (j = 0; j < n; j++) {
            if (!visited[j] && dist[j] < min) {
                min = dist[j];
                u = j;
            }
        }

        visited[u] = 1;

        // Update distances of adjacent vertices
        for (j = 0; j < n; j++) {
            if (!visited[j] && cost[u][j] != INT_MAX) {
                if (dist[u] + cost[u][j] < dist[j]) {
                    dist[j] = dist[u] + cost[u][j];
                }
            }
        }
    }

    // Output results
    printf("Shortest distances from vertex %d:\n", src);
    for (i = 0; i < n; i++) {
        if (dist[i] == INT_MAX) {
            printf("To %d: INF\n", i);
        } else {
            printf("To %d: %d\n", i, dist[i]);
        }
    }

    return 0;
}
