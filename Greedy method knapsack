#include <stdio.h>

int main()
{
    int n, i, j;
    float w[10], p[10], ratio[10];
    float cap, temp, temp1;
    float profit = 0;

    printf("Enter the total number of items: ");
    scanf("%d", &n);

    printf("Enter the weight of each item:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%f", &w[i]);
    }

    printf("Enter the profit of each item:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%f", &p[i]);
    }

    printf("Enter the capacity of knapsack: ");
    scanf("%f", &cap);

    // Calculate profit/weight ratio
    for(i = 0; i < n; i++)
    {
        ratio[i] = p[i] / w[i];
    }

    // Sort items based on ratio in descending order
    for(i = 0; i < n; i++)
    {
        for(j = i+1; j < n; j++)
        {
            if(ratio[i] < ratio[j])
            {
                temp = ratio[i];
                ratio[i] = ratio[j];
                ratio[j] = temp;

                temp1 = w[i];
                w[i] = w[j];
                w[j] = temp1;

                temp1 = p[i];
                p[i] = p[j];
                p[j] = temp1;
            }
        }
    }

    // Apply greedy method
    for(i = 0; i < n; i++)
    {
        if(w[i] <= cap)
        {
            cap = cap - w[i];
            profit = profit + p[i];
        }
        else
        {
            profit = profit + (cap * ratio[i]);
            break;
        }
    }

    printf("Maximum profit = %f", profit);

    return 0;
}
